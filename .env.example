# YouTube Meme Generator — environment configuration
#
# ALL keys below are OPTIONAL. If any/all are missing, the app runs in
# full DEMO/MOCK MODE: it generates fake video/comment data, uses a
# template-based caption generator instead of an LLM, and still renders
# real, playable mp4 files (image + burned-in text + a synthesized tone
# audio track) via ffmpeg so the entire pipeline is testable end-to-end
# with zero external accounts.

# YouTube Data API v3 key. Get one at https://console.cloud.google.com/
# (enable "YouTube Data API v3", create an API key).
# Without this, search results are generated by lib/mock.ts.
YOUTUBE_API_KEY=

# Groq API key(s) for caption generation (model: llama-3.3-70b-versatile),
# via https://api.groq.com/openai/v1/chat/completions — get a free key at
# https://console.groq.com/keys
# You can supply MULTIPLE keys comma-separated in GROQ_API_KEYS; requests
# are round-robin rotated across them (and a failed/rate-limited key falls
# through to the next one automatically), which matters here because all
# ~10 memes on a page generate their captions concurrently in parallel.
#   GROQ_API_KEYS=gsk_aaa,gsk_bbb
GROQ_API_KEYS=
# Single-key convenience alias (used only if GROQ_API_KEYS is unset).
GROQ_API_KEY=

# NVIDIA API key for the PaliGemma VLM endpoint
# (https://ai.api.nvidia.com/v1/vlm/google/paligemma). Used by the Comment
# Analyzer to describe the video thumbnail as extra context for funny meme
# generation. Optional — without it, memes are generated from text only.
NVIDIA_API_KEY=

# Optional explicit path to an ffmpeg binary. Normally ffmpeg-static's
# postinstall download is used; set this if that download is blocked in
# your environment (e.g. FFMPEG_PATH=/usr/bin/ffmpeg).
FFMPEG_PATH=

# Without any Groq key, /api/generate-caption falls back to a
# template-based joke/caption generator in lib/captionFallback.ts.
#
# Audio: every rendered mp4 uses an ffmpeg-generated sine-wave tone as a
# stub audio track (no TTS provider is wired up — real voiceover is not
# part of this app right now).
