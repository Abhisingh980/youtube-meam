# 2. SANITIZATION AND API DATA EXTRACTION
# ==========================================
def clean_comment_text(raw_text: str) -> str:
    """Removes un-encodable text artifacts and standardizes whitespace."""
    if not raw_text:
        return ""
    # Normalize characters, clean HTML formatting tags returned from API
    text = re.sub(r'<br\s*/?>', '\n', raw_text)
    text = re.sub(r'[^\x20-\x7E\n]', '', text)  # Keep printable ASCII characters
    return text.strip()

async def fetch_youtube_comments_page(video_id: str, developer_key: str, total_needed: int = 1000) -> List[str]:
    """
    Fetches raw text threads while navigating the API's maximum 100 per-request limit.
    Mitigates closed comment loops, empty payloads, and permission issues.
    """
    def _api_call():
        youtube = googleapiclient.discovery.build("youtube", "v3", developerKey=developer_key, cache_discovery=False)
        collected_comments = []
        next_page_token = None
        
        while len(collected_comments) < total_needed:
            try:
                # Max constraint allowed by YouTube endpoint is 100
                request = youtube.commentThreads().list(
                    part="snippet",
                    videoId=video_id,
                    maxResults=100,
                    textFormat="html",
                    pageToken=next_page_token
                )
                response = request.execute()
            except googleapiclient.errors.HttpError as e:
                # Catch closed comments (403) or missing/private videos (404)
                if e.resp.status in [403, 404]:
                    return collected_comments
                raise e

            for item in response.get("items", []):
                top_comment = item["snippet"]["topLevelComment"]["snippet"]["textOriginal"]
                cleaned = clean_comment_text(top_comment)
                if cleaned:
                    collected_comments.append(cleaned)
                    
            next_page_token = response.get("nextPageToken")
            if not next_page_token:
                break
                
        return collected_comments[:total_needed]

    return await asyncio.to_thread(_api_call)

