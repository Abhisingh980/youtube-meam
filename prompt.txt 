5. Media Compilation Pipeline (FFmpeg Integration)Once Claude returns the structured output, route the strings into an automated script wrapper using edge-tts (fast, free open-source TTS) and ffmpeg to build the final media without manual rendering overhead:Pythonimport subprocess

def compile_video_frame(audio_path: str, text_overlay: str, output_path: str):
    """
    Generates a video clip by overlaying the script text over a dark base 
    canvas, paired with the spoken comment track.
    """
    # Escape characters for safe shell pipeline processing
    escaped_text = text_overlay.replace("'", "'\\''")
    
    cmd = [
        'ffmpeg', '-y',
        '-f', 'lavfi', '-i', 'color=c=0x111111:s=1080x1920:r=30', # Create a clean 1080x1920 portrait canvas (Shorts/Reels)
        '-i', audio_path, # Inject the spoken voice file
        '-vf', f"drawtext=text='{escaped_text}':fontcolor=white:fontsize=48:x=(w-text_w)/2:y=(h-text_h)/2:word_wrap=1",
        '-c:v', 'libx264', '-tune', 'stillimage',
        '-c:a', 'aac', '-b:a', '192k',
        '-shortest', output_path # Truncate video immediately when audio track completes
    ]
    
    subprocess.run(cmd, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)