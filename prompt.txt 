def run_local_humor_screening(comments: List[str]) -> List[str]:
    """
    Runs a local open-source transformer model to down-sample huge arrays.
    Saves API tokens by screening out plain or boring comments first.
    """
    if not comments:
        return []
    
    # Utilizing an open-source sentiment or humor classification pipeline
    # Fallback to local CPU/GPU safe mini-pipeline models
    classifier = pipeline("sentiment-analysis", model="distilbert-base-uncased-finetuned-sst-2-english", device=-1)
    
    screened_results = []
    # Batch size processing minimizes model forward-pass bottlenecks
    batch_size = 64
    for i in range(0, len(comments), batch_size):
        chunk = comments[i:i + batch_size]
        # Mitigate string size explosion constraints
        truncated_chunk = [text[:250] for text in chunk]
        predictions = classifier(truncated_chunk)
        
        for idx, pred in enumerate(predictions):
            # Filtering for extreme sentiment / higher statistical variance 
            if pred['score'] > 0.75:
                screened_results.append(chunk[idx])
                
    return screened_results

