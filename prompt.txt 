async def orchestrate_meme_generation(video_id: str, youtube_key: str, anthropic_key: str, mode: str) -> MemeScriptOutput:
    # Step 1: Parallel/Async network extraction
    raw_comments = await fetch_youtube_comments_page(video_id, youtube_key, total_needed=1000)
    if not raw_comments:
        raise ValueError("Target video contains no extractable text comments or comments are disabled.")
        
    # Step 2: Offload local compute processing to process pool worker to prevent blocking the async loop
    loop = asyncio.get_running_loop()
    with ProcessPoolExecutor() as pool:
        screened_comments = await loop.run_in_executor(pool, run_local_humor_screening, raw_comments)
    
    # Absolute minimum fallback safety guard
    if not screened_comments:
        screened_comments = raw_comments[:50]
        
    # Step 3: Run structured transformation using LangChain & Claude
    llm = ChatAnthropic(
        model="claude-3-5-sonnet-20240620", 
        temperature=1.0, # High variance parameter boosts comedic patterns
        anthropic_api_key=anthropic_key
    )
    
    structured_llm = llm.with_structured_output(MemeScriptOutput)
    
    # Inject prompt instructions directly into execution run
    formatted_comments_payload = "\n".join([f"- {msg}" for msg in screened_comments[:100]])
    
    system_instruction = SYSTEM_MEME_PROMPT.format(format_choice=mode)
    user_payload = f"Analyze these raw video comment threads and build the script execution output:\n\n{formatted_comments_payload}"
    
    # Combined invocation guarantees strict schema adherence
    response = await structured_llm.ainvoke([
        ("system", system_instruction),
        ("human", user_payload)
    ])
    
    return response
